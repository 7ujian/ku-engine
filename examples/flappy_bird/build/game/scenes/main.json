      {
        "id": "bird",
        "type": "RigidBody",
        "properties": {
          "x": 150,
          "y": 220,
          "mass": 1,
          "velocity": { "x": 0, "y": 0 },
          "gravity_scale": 1,
          "linear_damping": 0,
          "dead": false
        },
        "children": [],
        "scripts": [
          {
            "event": "on_key",
            "filter": { "key": "SPACE" },
            "condition": { "dead": { "neq": true } },
            "actions": [
              { "set": "velocity.y", "to": -4 },
              { "log": "flap!" }
            ]
          },
          {
            "event": "on_key",
            "filter": { "key": "UP" },
            "condition": { "dead": { "neq": true } },
            "actions": [
              { "set": "velocity.y", "to": -4 }
            ]
          },
          {
            "event": "on_collision",
            "condition": { "dead": { "neq": true } },
            "actions": [
              { "set": "dead", "to": true },
              { "set": "velocity.y", "to": 0 },
              { "set": "gravity_scale", "to": 0 },
              { "log": "GAME OVER" }
            ]
          }
        ]
      },
